{
    "manifest_version": 3,
    "name": "网易云音乐一键下载",
    "version": "1.0",
    "description": "网易云网页版自动替换下载按钮，一键下载歌曲",
    "permissions": ["activeTab", "tabs", "scripting", "clipboardWrite", "downloads"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
      }
    },
    "icons": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "host_permissions": [
      "https://music.163.com/*",
      "http://music.163.com/*"
    ],
    "content_scripts": [
        {
          "matches": ["https://music.163.com/*"],
          "js": ["content-script.js"],
          "css": ["content-style.css"],
          "run_at": "document_end",
          "all_frames": true,
          "match_about_blank": true
        }
      ]
  }